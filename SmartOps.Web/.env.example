# Example environment variables for configuring Semantic Kernel OpenAI provider
# Copy this file to .env or set the variables in your environment before running the app.
# Do NOT commit real secrets to source control.

# OpenAI API key (required to enable OpenAI provider)
OPENAI_API_KEY=

# OpenAI model id to use (defaults to 'gpt-4o' when not set)
OPENAI_MODEL_ID=gpt-4o
